modules = ["nodejs-20", "web", "postgresql-16", "python-3.11"]
[agent]
expertMode = true
integrations = ["revenuecat:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Mockup Sandbox"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsc --noEmit 2>&1 | head -20 || true; echo 'MoodRx — React Native/Expo project'; echo 'Use EAS (GitHub Actions) to build for Android/iOS'; echo 'Repo: github.com/soul2fade/moodrx'"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Mockup Sandbox"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/mockup-sandbox && PORT=5000 BASE_PATH=/__mockup/ npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23637
externalPort = 3002

[deployment]
deploymentTarget = "static"
build = ["npx", "expo", "export", "--platform", "web"]
publicDir = "dist"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000

[userenv]

[userenv.shared]
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY = "test_dLQldoOvEOufmPZoFoJRXfpqWQU"
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY = "appl_cVmaSBaUVAlgatSJqDmFjVXReRD"
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY = "goog_CcFgmogOBsOonqVQhWkBfyWWlKM"
REVENUECAT_PROJECT_ID = "projead2b038"
REVENUECAT_TEST_STORE_APP_ID = "appcf1de2875e"
REVENUECAT_APPLE_APP_STORE_APP_ID = "appa97ed33ec8"
REVENUECAT_GOOGLE_PLAY_STORE_APP_ID = "appb072c40d0f"
